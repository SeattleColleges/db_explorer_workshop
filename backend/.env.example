# APP
NODE_ENV=development
PORT=3001

# Database — Supabase PostgreSQL direct connection
# ways to grab your connection string
# 1 - just copy it from your browser URL while you're inside your project
# 2 - navigate to your project and find the value right below the project's name
# 3 - go to your project -> project settings -> Data API -> grab the value

# Special characters in the password must be percent-encoded:
#   #  →  %23       @  →  %40       $  →  %24       !  →  %21

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# The Supabase table to query — set this to the name of your table
TABLE_NAME=your_table_name

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
